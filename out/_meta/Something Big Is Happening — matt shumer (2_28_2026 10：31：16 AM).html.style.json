{
  "genre": "essay",
  "stance": "addressing_reader",
  "default_register": "합니다체",
  "pov_base": "저는",
  "reader_address": "여러분",
  "permitted_shifts": {
    "quote_blocks": true,
    "emphasis_blocks": true,
    "reader_address_blocks": true,
    "scope": "paragraph_only"
  },
  "html_mode": true,
  "html_scope": {
    "translate_only_visible_text": true,
    "include_tags": ["article"],
    "include_selectors": ["p", "h1", "h2", "h3", "li", "blockquote"],
    "exclude_selectors": ["head", "title", "meta", "script", "style", "pre", "code", ".sf-hidden", "nav", "footer", "form"]
  },
  "forbidden": [
    "noun_only_sentences",
    "random_register_mixing",
    "html_tag_attr_changes",
    "punctuation_spacing_loss"
  ],
  "notes": "개인 에세이 톤을 유지하되 경고성 메시지는 단정적으로 전달."
}
